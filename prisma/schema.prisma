generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Shared / Seeded Data (global, no userId) ─────────────────────────────────

model Exercise {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  primaryMuscles   String   @default("[]")   // JSON array
  secondaryMuscles String   @default("[]")   // JSON array
  equipment        String   @default("Barbell")
  movementPattern  String   @default("Push")
  jointStress      String   @default("{}")   // JSON object
  defaultRepRange  String   @default("8-12")
  sfrRating        Float    @default(3.0)
  notes            String?
  substitutions    String   @default("[]")   // JSON array
  isSeeded         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userOverrides    UserExerciseOverride[]
  plannedExercises PlannedExercise[]
  loggedSets       LoggedSet[]
}

// ─── Per-user exercise preferences (favorites, excluded) ─────────────────────

model UserExerciseOverride {
  id         Int      @id @default(autoincrement())
  userId     String
  exerciseId Int
  isFavorite Boolean  @default(false)
  isExcluded Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())

  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
}

// ─── User-scoped models ───────────────────────────────────────────────────────

model MuscleGroup {
  id               Int      @id @default(autoincrement())
  userId           String
  name             String
  mev              Int      @default(8)
  mav              Int      @default(14)
  mrv              Int      @default(20)
  defaultFrequency Int      @default(2)
  priorityTier     String   @default("Medium")
  injured          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Mesocycle {
  id           Int       @id @default(autoincrement())
  userId       String
  name         String
  startDate    DateTime?
  endDate      DateTime?
  status       String    @default("planning")
  weeks        Int       @default(4)
  trainingDays String    @default("[]")   // JSON array
  goal         String    @default("Pure Hypertrophy")
  focusMuscles String    @default("[]")   // JSON array
  progression  String    @default("Standard")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  mesocycleWeeks MesocycleWeek[]

  @@index([userId])
}

model MesocycleWeek {
  id          Int      @id @default(autoincrement())
  mesocycleId Int
  weekNumber  Int
  isDeload    Boolean  @default(false)
  volumePlan  String   @default("{}")   // JSON: { muscle: setCount }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mesocycle    Mesocycle     @relation(fields: [mesocycleId], references: [id], onDelete: Cascade)
  workoutPlans WorkoutPlan[]

  @@unique([mesocycleId, weekNumber])
  @@index([mesocycleId])
}

model WorkoutPlan {
  id              Int      @id @default(autoincrement())
  mesocycleWeekId Int
  dayOfWeek       Int
  muscleGroups    String   @default("[]")   // JSON array
  label           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mesocycleWeek    MesocycleWeek     @relation(fields: [mesocycleWeekId], references: [id], onDelete: Cascade)
  plannedExercises PlannedExercise[]
  sessions         Session[]

  @@index([mesocycleWeekId])
}

model PlannedExercise {
  id            Int      @id @default(autoincrement())
  workoutPlanId Int
  exerciseId    Int
  plannedSets   Int      @default(3)
  repRange      String   @default("8-12")
  targetRir     Int      @default(3)
  suggestedLoad Float?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id])

  @@index([workoutPlanId])
  @@index([exerciseId])
}

model Session {
  id              Int       @id @default(autoincrement())
  userId          String
  date            DateTime  @default(now())
  workoutPlanId   Int?
  durationMinutes Int?
  fatigueScore    Int?
  notes           String?
  completed       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workoutPlan WorkoutPlan? @relation(fields: [workoutPlanId], references: [id])
  loggedSets  LoggedSet[]

  @@index([userId])
  @@index([workoutPlanId])
}

model LoggedSet {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  exerciseId  Int
  setNumber   Int
  weight      Float    @default(0)
  reps        Int      @default(0)
  rirAchieved Int?
  tempo       String?
  isWarmup    Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  session  Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@index([exerciseId])
}

model BodyMetric {
  id           Int      @id @default(autoincrement())
  userId       String
  date         DateTime @default(now())
  bodyweight   Float?
  measurements String   @default("{}")   // JSON
  notes        String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Setting {
  id        Int      @id @default(autoincrement())
  userId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}
